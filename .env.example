# ============================================================
# PROMETHEUS WISDOM — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All values have sensible defaults — zero-config is the goal.

# --- Google Gemini (Cloud LLM Fallback) ---
# Get free API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# --- Ollama (Local LLM — Primary) ---
# Install: https://ollama.ai
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Neo4j Aura (Knowledge Graph — Optional) ---
# Free tier: https://neo4j.com/cloud/aura-free/
# If not set, WISDOM uses SQLite-based graph fallback
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# --- Local Storage ---
# Path for SQLite database (default: ./data/wisdom.db)
WISDOM_DB_PATH=./data/wisdom.db

# Path for ChromaDB vector store (default: ./data/chroma)
CHROMA_DB_PATH=./data/chroma

# --- Application Settings ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Default language (auto-detected from user's first message)
DEFAULT_LANGUAGE=en

# Maximum conversation history (short-term memory)
MAX_MEMORY_MESSAGES=20
